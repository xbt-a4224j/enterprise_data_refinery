# Enterprise Data Refinery — configuration
EDR_DATABASE_URL=postgresql+psycopg://edr:edr@db:5432/edr
EDR_LLM_PROVIDER=ollama          # ollama | claude | fake
EDR_OLLAMA_HOST=http://ollama:11434
EDR_OLLAMA_MODEL=qwen2.5:7b
EDR_ANTHROPIC_API_KEY=           # only needed when EDR_LLM_PROVIDER=claude (set in YOUR env; never commit)
EDR_ANTHROPIC_MODEL=claude-haiku-4-5   # or claude-sonnet-5 / claude-opus-4-8
EDR_ADMIN_TOKEN=change-me        # admin/control routes
EDR_SLACK_WEBHOOK=               # optional alerting
